---
import Layout from '../layouts/Layout.astro';
import CodeBlock from '../components/CodeBlock.astro';
import { HARNESSES } from '../lib/harnesses';

const base = import.meta.env.BASE_URL;
const link = (p: string) => `${base.replace(/\/$/, '')}/${p.replace(/^\//, '')}`;
---

<Layout
  title="Quick start"
  description="Install a self-driving agent on your harness in one command."
>
  <section class="border-b border-ink-200 bg-white">
    <div class="mx-auto max-w-4xl px-6 py-12">
      <p class="text-sm font-medium uppercase tracking-wide text-accent-600">
        Get started
      </p>
      <h1 class="mt-2 text-3xl font-bold text-ink-900 sm:text-4xl">Quick start</h1>
      <p class="mt-3 max-w-2xl text-ink-500">
        One CLI call sets up the memory bank, ingests seed knowledge, and registers the
        agent with your harness. Pick an agent, pick a harness, run.
      </p>
    </div>
  </section>

  <!-- Pre-reqs -->
  <section class="border-b border-ink-200 bg-ink-50">
    <div class="mx-auto max-w-4xl px-6 py-10">
      <h2 class="text-xl font-semibold text-ink-900">Before you start</h2>
      <ul class="mt-4 space-y-2 text-sm text-ink-700">
        <li class="flex gap-2">
          <span class="mt-1 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-accent-500" />
          A supported harness (Claude Chat, Claude Cowork, OpenClaw, or NemoClaw).
        </li>
        <li class="flex gap-2">
          <span class="mt-1 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-accent-500" />
          A Hindsight account — <a class="text-accent-600 hover:underline" href="https://hindsight.vectorize.io" target="_blank" rel="noopener">Cloud</a> or self-hosted.
        </li>
        <li class="flex gap-2">
          <span class="mt-1 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-accent-500" />
          Node.js 22+ on the machine running the CLI.
        </li>
      </ul>
    </div>
  </section>

  <!-- Steps -->
  <section class="border-b border-ink-200 bg-white">
    <div class="mx-auto max-w-4xl px-6 py-10">
      <h2 class="text-xl font-semibold text-ink-900">Install in one command</h2>
      <p class="mt-2 text-sm text-ink-500">
        Replace the agent slug or harness flag as needed.
      </p>

      <div class="mt-6 space-y-4">
        {HARNESSES.map((h) => (
          <div class="rounded-xl border border-ink-200 bg-ink-50 p-5">
            <div class="mb-3 flex items-center justify-between">
              <h3 class="font-semibold text-ink-900">{h.name}</h3>
              <a
                href={link(`/harnesses/${h.slug}`)}
                class="text-sm font-medium text-accent-600 hover:underline"
              >
                Full guide →
              </a>
            </div>
            <CodeBlock
              code={`npx @vectorize-io/self-driving-agents install marketing/seo ${h.flag}`}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Custom agent -->
  <section class="border-b border-ink-200 bg-ink-50">
    <div class="mx-auto max-w-4xl px-6 py-10">
      <h2 class="text-xl font-semibold text-ink-900">Use your own agent</h2>
      <p class="mt-2 text-sm text-ink-500">
        An agent is just a directory: a <code class="rounded bg-ink-100 px-1 py-0.5">bank-template.json</code> next to one or more <code class="rounded bg-ink-100 px-1 py-0.5">.md</code> files.
      </p>

      <div class="mt-5">
        <CodeBlock
          lang="text"
          code={`my-agent/
  bank-template.json     # memory bank + knowledge pages config
  playbook.md            # any .md/.txt becomes seed knowledge
  advanced-tips.md`}
        />
      </div>

      <p class="mt-4 text-sm text-ink-600">Local path:</p>
      <div class="mt-2">
        <CodeBlock code="npx @vectorize-io/self-driving-agents install ./my-agent --harness claude" />
      </div>

      <p class="mt-4 text-sm text-ink-600">Or from any GitHub repo:</p>
      <div class="mt-2">
        <CodeBlock code="npx @vectorize-io/self-driving-agents install my-org/my-repo/my-agent --harness openclaw" />
      </div>
    </div>
  </section>

  <!-- Next -->
  <section class="bg-white">
    <div class="mx-auto max-w-4xl px-6 py-10">
      <h2 class="text-xl font-semibold text-ink-900">Next steps</h2>
      <div class="mt-5 grid gap-4 sm:grid-cols-2">
        <a
          href={link('/agents')}
          class="rounded-xl border border-ink-200 bg-ink-50 p-5 transition hover:border-accent-300 hover:bg-white"
        >
          <h3 class="font-semibold text-ink-900">Browse agents</h3>
          <p class="mt-1 text-sm text-ink-500">
            Pick a marketing specialty or install the whole department.
          </p>
        </a>
        <a
          href={link('/harnesses')}
          class="rounded-xl border border-ink-200 bg-ink-50 p-5 transition hover:border-accent-300 hover:bg-white"
        >
          <h3 class="font-semibold text-ink-900">Compare harnesses</h3>
          <p class="mt-1 text-sm text-ink-500">
            Detailed setup for Claude, OpenClaw, NemoClaw.
          </p>
        </a>
      </div>
    </div>
  </section>
</Layout>
