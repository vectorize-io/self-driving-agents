---
import Layout from '../../layouts/Layout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import { flattenAgents, type AgentNode, type AgentFile } from '../../lib/agents';
import { HARNESSES } from '../../lib/harnesses';
import { marked } from 'marked';

export async function getStaticPaths() {
  const agents = flattenAgents();
  return agents.map((agent) => ({
    params: { slug: agent.slug },
    props: { agent },
  }));
}

interface Props {
  agent: AgentNode;
}
const { agent } = Astro.props;

const base = import.meta.env.BASE_URL;
const link = (p: string) => `${base.replace(/\/$/, '')}/${p.replace(/^\//, '')}`;

// breadcrumbs
const segments = agent.slug.split('/');
const crumbs = segments.map((seg, i) => {
  const slug = segments.slice(0, i + 1).join('/');
  return { label: seg, href: link(`/agents/${slug}`) };
});

const installCmd = (slug: string) =>
  `npx @vectorize-io/self-driving-agents install ${agent.slug} --harness ${slug}`;

const renderMd = (md: string): string => {
  // simple, safe-enough rendering — content is from this repo
  return marked.parse(md, { async: false }) as string;
};

const colorOf = (f: AgentFile) => {
  const c = f.color;
  if (!c) return '#3a5ef0';
  if (/^#[0-9a-f]{3,8}$/i.test(c)) return c;
  // named CSS colors pass through
  return c;
};
---

<Layout title={agent.displayName} description={agent.bank?.reflect_mission ?? ''}>
  <!-- Header -->
  <section class="border-b border-ink-200 bg-white">
    <div class="mx-auto max-w-5xl px-6 py-10">
      <nav class="mb-4 flex flex-wrap items-center gap-1 text-xs text-ink-400">
        <a href={link('/agents')} class="hover:text-ink-600">agents</a>
        {crumbs.map((c) => (
          <>
            <span>/</span>
            <a href={c.href} class="hover:text-ink-600">{c.label}</a>
          </>
        ))}
      </nav>

      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <h1 class="text-3xl font-bold text-ink-900 sm:text-4xl">
            {agent.displayName}
          </h1>
          <p class="mt-1 font-mono text-sm text-ink-400">{agent.slug}</p>
        </div>
        <div class="flex flex-wrap gap-2 text-sm">
          <span class="rounded-full bg-ink-100 px-3 py-1 text-ink-600">
            {agent.totalFiles} knowledge {agent.totalFiles === 1 ? 'file' : 'files'}
          </span>
          {agent.children.length > 0 && (
            <span class="rounded-full bg-ink-100 px-3 py-1 text-ink-600">
              {agent.children.length} sub-agents
            </span>
          )}
          {agent.mentalModels.length > 0 && (
            <span class="rounded-full bg-ink-100 px-3 py-1 text-ink-600">
              {agent.mentalModels.length} mental models
            </span>
          )}
        </div>
      </div>

      {agent.bank?.reflect_mission && (
        <p class="mt-5 max-w-3xl text-lg leading-relaxed text-ink-600">
          {agent.bank.reflect_mission}
        </p>
      )}
    </div>
  </section>

  <!-- Install -->
  <section class="border-b border-ink-200 bg-ink-50">
    <div class="mx-auto max-w-5xl px-6 py-10">
      <h2 class="text-xl font-semibold text-ink-900">Install</h2>
      <p class="mt-1 text-sm text-ink-500">
        Pick the harness that matches where you'll chat with the agent.
      </p>

      <div class="mt-5 grid gap-4 sm:grid-cols-2">
        {HARNESSES.map((h) => (
          <div class="rounded-xl border border-ink-200 bg-white p-4">
            <div class="mb-2 flex items-center justify-between">
              <span class="text-sm font-semibold text-ink-900">{h.name}</span>
              <a
                href={link(`/harnesses/${h.slug}`)}
                class="text-xs font-medium text-accent-600 hover:underline"
              >
                docs →
              </a>
            </div>
            <CodeBlock code={installCmd(h.slug)} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Memory bank -->
  {agent.bank && (
    <section class="border-b border-ink-200 bg-white">
      <div class="mx-auto max-w-5xl px-6 py-10">
        <h2 class="text-xl font-semibold text-ink-900">Memory bank</h2>
        <p class="mt-1 text-sm text-ink-500">
          How this agent thinks about its own memory.
        </p>

        <div class="mt-5 grid gap-4 md:grid-cols-2">
          {agent.bank.reflect_mission && (
            <div class="rounded-xl border border-ink-200 bg-ink-50 p-4">
              <h3 class="text-sm font-semibold uppercase tracking-wide text-ink-500">
                Reflect mission
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-700">
                {agent.bank.reflect_mission}
              </p>
            </div>
          )}
          {agent.bank.retain_mission && (
            <div class="rounded-xl border border-ink-200 bg-ink-50 p-4">
              <h3 class="text-sm font-semibold uppercase tracking-wide text-ink-500">
                Retain mission
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-700">
                {agent.bank.retain_mission}
              </p>
            </div>
          )}
        </div>

        <!-- Dispositions -->
        <div class="mt-5 grid gap-3 sm:grid-cols-3">
          {[
            { label: 'Empathy', value: agent.bank.disposition_empathy },
            { label: 'Skepticism', value: agent.bank.disposition_skepticism },
            { label: 'Literalism', value: agent.bank.disposition_literalism },
          ]
            .filter((d) => typeof d.value === 'number')
            .map((d) => (
              <div class="rounded-lg border border-ink-200 bg-white p-3">
                <div class="text-xs font-medium uppercase tracking-wide text-ink-400">
                  {d.label}
                </div>
                <div class="mt-1 flex items-center justify-between">
                  <span class="text-lg font-semibold text-ink-900">{d.value} / 5</span>
                  <div class="flex gap-0.5">
                    {Array.from({ length: 5 }).map((_, i) => (
                      <span
                        class={
                          'h-2 w-2 rounded-full ' +
                          (i < (d.value as number) ? 'bg-accent-500' : 'bg-ink-200')
                        }
                      />
                    ))}
                  </div>
                </div>
              </div>
            ))}
        </div>

        {agent.mentalModels.length > 0 && (
          <div class="mt-8">
            <h3 class="text-sm font-semibold uppercase tracking-wide text-ink-500">
              Mental models
            </h3>
            <div class="mt-3 space-y-3">
              {agent.mentalModels.map((m) => (
                <div class="rounded-lg border border-ink-200 bg-ink-50 p-4">
                  <div class="flex flex-wrap items-baseline justify-between gap-2">
                    <h4 class="font-semibold text-ink-900">{m.name}</h4>
                    <code class="text-xs text-ink-400">{m.id}</code>
                  </div>
                  {m.source_query && (
                    <p class="mt-2 text-sm leading-relaxed text-ink-600">
                      {m.source_query}
                    </p>
                  )}
                </div>
              ))}
            </div>
          </div>
        )}

        {agent.directives.length > 0 && (
          <div class="mt-8">
            <h3 class="text-sm font-semibold uppercase tracking-wide text-ink-500">
              Directives
            </h3>
            <div class="mt-3 space-y-3">
              {agent.directives.map((d) => (
                <div class="rounded-lg border-l-4 border-accent-500 bg-ink-50 p-4">
                  <div class="font-semibold text-ink-900">{d.name}</div>
                  <p class="mt-1 text-sm leading-relaxed text-ink-600">{d.content}</p>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- Sub-agents -->
  {agent.children.length > 0 && (
    <section class="border-b border-ink-200 bg-ink-50">
      <div class="mx-auto max-w-5xl px-6 py-10">
        <h2 class="text-xl font-semibold text-ink-900">Sub-agents</h2>
        <p class="mt-1 text-sm text-ink-500">
          Specialized templates inside <code class="rounded bg-ink-100 px-1 py-0.5">{agent.slug}</code>.
        </p>
        <div class="mt-5 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {agent.children.map((c) => (
            <a
              href={link(`/agents/${c.slug}`)}
              class="group rounded-xl border border-ink-200 bg-white p-5 transition hover:-translate-y-0.5 hover:border-accent-300"
            >
              <div class="text-xs font-mono text-ink-400">{c.slug}</div>
              <h3 class="mt-1 font-semibold text-ink-900 group-hover:text-accent-700">
                {c.displayName}
              </h3>
              <p class="mt-1 text-xs text-ink-500">
                {c.totalFiles} {c.totalFiles === 1 ? 'file' : 'files'}
              </p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Knowledge files -->
  {agent.files.length > 0 && (
    <section class="border-b border-ink-200 bg-white">
      <div class="mx-auto max-w-5xl px-6 py-10">
        <h2 class="text-xl font-semibold text-ink-900">Knowledge files</h2>
        <p class="mt-1 text-sm text-ink-500">
          Seed knowledge ingested when the agent is installed.
        </p>

        <div class="mt-5 space-y-4">
          {agent.files.map((f) => (
            <details
              class="group rounded-xl border border-ink-200 bg-ink-50 transition open:bg-white"
            >
              <summary
                class="flex cursor-pointer items-start gap-3 p-5 list-none"
              >
                <span
                  class="mt-1 inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-lg text-base text-white"
                  style={`background-color: ${colorOf(f)};`}
                  aria-hidden="true"
                >
                  {f.emoji ?? '◈'}
                </span>
                <div class="min-w-0 flex-1">
                  <div class="flex flex-wrap items-baseline justify-between gap-2">
                    <h3 class="font-semibold text-ink-900">{f.name}</h3>
                    <code class="font-mono text-xs text-ink-400">{f.fileName}</code>
                  </div>
                  {f.description && (
                    <p class="mt-1 text-sm leading-relaxed text-ink-500">
                      {f.description}
                    </p>
                  )}
                  {f.vibe && (
                    <p class="mt-2 text-xs italic text-ink-400">"{f.vibe}"</p>
                  )}
                  {f.tools && (
                    <div class="mt-2 flex flex-wrap gap-1">
                      {f.tools.split(',').map((t) => (
                        <span class="rounded bg-ink-100 px-1.5 py-0.5 font-mono text-xs text-ink-600">
                          {t.trim()}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
                <span
                  class="shrink-0 self-center text-ink-400 transition group-open:rotate-180"
                  aria-hidden="true"
                >
                  ▾
                </span>
              </summary>
              <div class="border-t border-ink-200 px-5 py-4">
                <article class="prose-doc" set:html={renderMd(f.body)} />
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
