---
import Layout from '../../layouts/Layout.astro';
import AgentCard from '../../components/AgentCard.astro';
import { loadRoots, flattenAgents, type AgentNode } from '../../lib/agents';

const roots = loadRoots();
const allAgents = flattenAgents(roots);

const base = import.meta.env.BASE_URL;
const link = (p: string) => `${base.replace(/\/$/, '')}/${p.replace(/^\//, '')}`;

// Build a search haystack per card so all filtering happens client-side
// without re-fetching anything.
function searchText(a: AgentNode): string {
  const parts: string[] = [
    a.slug,
    a.displayName,
    a.bank?.reflect_mission ?? '',
    a.bank?.retain_mission ?? '',
    a.children.map((c) => c.displayName).join(' '),
    a.files.map((f) => `${f.name} ${f.description}`).join(' '),
    a.mentalModels.map((m) => m.name).join(' '),
  ];
  return parts.join(' ').toLowerCase();
}

const cards = allAgents.map((a) => ({
  agent: a,
  isTopLevel: a.segments.length === 1,
  search: searchText(a),
}));

const topLevelCount = cards.filter((c) => c.isTopLevel).length;
const totalCount = cards.length;
---

<Layout
  title="Agents"
  description="Browse self-driving agent templates. Search across every department, specialist, and knowledge file."
>
  <section class="border-b border-ink-200 bg-white">
    <div class="mx-auto max-w-6xl px-6 py-12">
      <p class="text-sm font-medium uppercase tracking-wide text-accent-600">
        Templates
      </p>
      <h1 class="mt-2 text-3xl font-bold text-ink-900 sm:text-4xl">
        Available agents
      </h1>
      <p class="mt-3 max-w-2xl text-ink-500">
        Top-level departments are listed below. Use search to drill into
        specialists, knowledge files, or mental models.
      </p>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-6xl px-6 py-10">
      <!-- Search -->
      <div
        class="sticky top-14 z-10 -mx-2 mb-6 flex flex-wrap items-center gap-3 rounded-xl border border-ink-200 bg-white/95 p-3 shadow-sm backdrop-blur"
      >
        <div class="relative flex-1 min-w-[220px]">
          <span
            class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-ink-400"
            aria-hidden="true"
          >
            ⌕
          </span>
          <input
            id="agent-search"
            type="search"
            placeholder="Search agents, files, missions…"
            class="w-full rounded-lg border border-ink-200 bg-ink-50 py-2 pl-9 pr-3 text-sm text-ink-800 placeholder-ink-400 outline-none transition focus:border-accent-400 focus:bg-white focus:ring-2 focus:ring-accent-200"
            autocomplete="off"
            spellcheck="false"
          />
        </div>
        <div class="flex items-center gap-2 text-xs text-ink-500">
          <span id="agent-count" data-top-level={topLevelCount} data-total={totalCount}>
            Showing {topLevelCount} of {totalCount}
          </span>
          <button
            id="agent-clear"
            type="button"
            class="hidden rounded-md border border-ink-200 bg-white px-2 py-1 font-medium text-ink-600 transition hover:border-ink-300"
          >
            Clear
          </button>
        </div>
      </div>

      <!-- Cards -->
      <div id="agent-grid" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {cards.map(({ agent, isTopLevel, search }) => (
          <div
            class="agent-card-wrap"
            data-search={search}
            data-top-level={isTopLevel ? '1' : '0'}
            data-slug={agent.slug}
          >
            <AgentCard agent={agent} href={link(`/agents/${agent.slug}`)} />
          </div>
        ))}
      </div>

      <!-- Empty state -->
      <div
        id="agent-empty"
        class="mt-8 hidden rounded-xl border border-dashed border-ink-200 bg-ink-50 p-10 text-center"
      >
        <p class="text-sm font-semibold text-ink-700">No matches.</p>
        <p class="mt-1 text-sm text-ink-500">
          Try a different keyword, or clear the search to see all top-level
          agents.
        </p>
      </div>
    </div>
  </section>
</Layout>

<script>
  const input = document.getElementById('agent-search') as HTMLInputElement | null;
  const grid = document.getElementById('agent-grid');
  const empty = document.getElementById('agent-empty');
  const counter = document.getElementById('agent-count');
  const clearBtn = document.getElementById('agent-clear');

  if (input && grid && counter) {
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.agent-card-wrap'));
    const totalCount = Number(counter.dataset.total ?? cards.length);
    const topLevelCount = Number(
      counter.dataset.topLevel ??
        cards.filter((c) => c.dataset.topLevel === '1').length,
    );

    const apply = () => {
      const q = input.value.trim().toLowerCase();
      let shown = 0;

      if (q === '') {
        for (const c of cards) {
          const visible = c.dataset.topLevel === '1';
          c.style.display = visible ? '' : 'none';
          if (visible) shown++;
        }
        counter.textContent = `Showing ${shown} of ${totalCount}`;
        clearBtn?.classList.add('hidden');
      } else {
        for (const c of cards) {
          const hay = c.dataset.search ?? '';
          const visible = hay.includes(q);
          c.style.display = visible ? '' : 'none';
          if (visible) shown++;
        }
        counter.textContent =
          shown === 0
            ? `No match in ${totalCount}`
            : `${shown} match${shown === 1 ? '' : 'es'} in ${totalCount}`;
        clearBtn?.classList.remove('hidden');
      }

      if (empty) empty.classList.toggle('hidden', shown !== 0);
    };

    input.addEventListener('input', apply);
    clearBtn?.addEventListener('click', () => {
      input.value = '';
      input.focus();
      apply();
    });

    // Slash to focus
    document.addEventListener('keydown', (e) => {
      if (e.key === '/' && document.activeElement !== input) {
        const tag = (document.activeElement?.tagName ?? '').toLowerCase();
        if (tag === 'input' || tag === 'textarea') return;
        e.preventDefault();
        input.focus();
        input.select();
      }
    });

    apply();
  }
</script>
