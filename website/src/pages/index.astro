---
import Layout from '../layouts/Layout.astro';
import AgentCard from '../components/AgentCard.astro';
import CodeBlock from '../components/CodeBlock.astro';
import { loadRootAgent } from '../lib/agents';
import { HARNESSES } from '../lib/harnesses';

const root = loadRootAgent();
const featured = [root, ...root.children];

const base = import.meta.env.BASE_URL;
const link = (p: string) => `${base.replace(/\/$/, '')}/${p.replace(/^\//, '')}`;
---

<Layout>
  <!-- Hero -->
  <section class="border-b border-ink-200 bg-gradient-to-b from-white to-ink-50">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <div class="max-w-3xl">
        <span
          class="inline-block rounded-full border border-ink-200 bg-white px-3 py-1 text-xs font-medium text-ink-500"
        >
          Powered by Hindsight · Portable agent memory
        </span>
        <h1
          class="mt-5 text-4xl font-extrabold tracking-tight text-ink-900 sm:text-5xl md:text-6xl"
        >
          Agents that{' '}
          <span class="text-accent-600">learn from every conversation</span>
          {' '}and get better over time.
        </h1>
        <p class="mt-5 text-lg leading-relaxed text-ink-500">
          Install in one command. They build their own knowledge pages, remember what you
          like, and keep themselves current — across Claude, OpenClaw, and NemoClaw.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a
            href={link('/quickstart')}
            class="rounded-lg bg-accent-500 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-accent-600"
          >
            Quick start →
          </a>
          <a
            href={link('/agents')}
            class="rounded-lg border border-ink-200 bg-white px-5 py-2.5 text-sm font-semibold text-ink-700 transition hover:border-ink-300"
          >
            Browse agents
          </a>
        </div>

        <div class="mt-10 max-w-2xl">
          <CodeBlock
            code="npx @vectorize-io/self-driving-agents install marketing/seo --harness claude"
          />
          <p class="mt-2 text-xs text-ink-400">
            Replace the agent slug or harness flag with whichever combo you want.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-b border-ink-200 bg-white">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <div class="mb-10 max-w-2xl">
        <h2 class="text-2xl font-bold text-ink-900 sm:text-3xl">How it works</h2>
        <p class="mt-2 text-ink-500">
          You never tell the agent to "save" or "remember." It decides what matters and
          keeps itself current.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {[
          {
            n: '1',
            title: 'You chat with the agent',
            body:
              'Use it like any normal assistant. Ask questions, give feedback, share context.',
          },
          {
            n: '2',
            title: 'Memory is retained',
            body:
              'Conversations are auto-summarized into Hindsight as durable, structured memory.',
          },
          {
            n: '3',
            title: 'Knowledge pages update themselves',
            body:
              'After each session the agent rewrites the pages it owns — playbooks, references, preferences.',
          },
          {
            n: '4',
            title: 'Next session it remembers',
            body:
              'On the next chat the agent reads its current pages — it knows what works and what you prefer.',
          },
        ].map((step) => (
          <div class="rounded-xl border border-ink-200 bg-ink-50 p-5">
            <div
              class="mb-3 flex h-8 w-8 items-center justify-center rounded-md bg-accent-500 text-sm font-semibold text-white"
            >
              {step.n}
            </div>
            <h3 class="font-semibold text-ink-900">{step.title}</h3>
            <p class="mt-1 text-sm leading-relaxed text-ink-500">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Available agents -->
  <section class="border-b border-ink-200 bg-ink-50">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <div class="mb-8 flex flex-wrap items-end justify-between gap-3">
        <div>
          <h2 class="text-2xl font-bold text-ink-900 sm:text-3xl">Available agents</h2>
          <p class="mt-2 text-ink-500">
            Install the whole department or pick a specialty.
          </p>
        </div>
        <a
          href={link('/agents')}
          class="text-sm font-medium text-accent-600 hover:underline"
        >
          See all agents →
        </a>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {featured.map((a) => (
          <AgentCard agent={a} href={link(`/agents/${a.slug}`)} />
        ))}
      </div>
    </div>
  </section>

  <!-- Harnesses -->
  <section class="border-b border-ink-200 bg-white">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <div class="mb-8 flex flex-wrap items-end justify-between gap-3">
        <div>
          <h2 class="text-2xl font-bold text-ink-900 sm:text-3xl">Harnesses</h2>
          <p class="mt-2 text-ink-500">
            Same agent, different runtimes. Pick the one you already use.
          </p>
        </div>
        <a
          href={link('/harnesses')}
          class="text-sm font-medium text-accent-600 hover:underline"
        >
          Compare harnesses →
        </a>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        {HARNESSES.map((h) => (
          <a
            href={link(`/harnesses/${h.slug}`)}
            class="group flex flex-col rounded-xl border border-ink-200 bg-ink-50 p-6 transition hover:-translate-y-0.5 hover:border-accent-300 hover:bg-white"
          >
            <span
              class="inline-flex h-9 w-9 items-center justify-center rounded-lg text-white"
              style={`background-color: ${h.color};`}
              aria-hidden="true"
            >
              ◉
            </span>
            <h3 class="mt-4 text-lg font-semibold text-ink-900 group-hover:text-accent-700">
              {h.name}
            </h3>
            <p class="mt-1 text-sm leading-relaxed text-ink-500">{h.tagline}</p>
            <code class="mt-4 inline-block w-fit rounded bg-ink-100 px-2 py-1 text-xs text-ink-700">
              {h.flag}
            </code>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Roll your own -->
  <section class="bg-ink-900 text-ink-100">
    <div class="mx-auto grid max-w-6xl items-start gap-10 px-6 py-16 lg:grid-cols-2">
      <div>
        <h2 class="text-2xl font-bold text-white sm:text-3xl">
          Or roll your own agent.
        </h2>
        <p class="mt-3 text-ink-300">
          An agent is just a directory: drop a <code class="rounded bg-ink-700 px-1.5 py-0.5">bank-template.json</code> next to some
          markdown files and point the CLI at it. Same self-driving behavior, your domain.
        </p>
        <a
          href="https://github.com/vectorize-io/self-driving-agents#create-your-own"
          target="_blank"
          rel="noopener"
          class="mt-6 inline-flex items-center rounded-lg bg-accent-500 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-accent-400"
        >
          Read the spec →
        </a>
      </div>

      <div>
        <CodeBlock
          lang="text"
          code={`my-agent/
  bank-template.json     # memory bank + knowledge pages config
  playbook.md            # any .md/.txt becomes seed knowledge
  advanced-tips.md`}
        />
        <div class="mt-3">
          <CodeBlock
            code="npx @vectorize-io/self-driving-agents install ./my-agent --harness claude"
          />
        </div>
      </div>
    </div>
  </section>
</Layout>
