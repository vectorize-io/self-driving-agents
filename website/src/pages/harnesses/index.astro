---
import Layout from '../../layouts/Layout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import HarnessLogo from '../../components/HarnessLogo.astro';
import { HARNESSES } from '../../lib/harnesses';

const base = import.meta.env.BASE_URL;
const link = (p: string) => `${base.replace(/\/$/, '')}/${p.replace(/^\//, '')}`;
---

<Layout
  title="Harnesses"
  description="Run self-driving agents on Claude, OpenClaw, or NemoClaw — same agent definition, different runtimes."
>
  <section class="border-b border-ink-200 bg-white">
    <div class="mx-auto max-w-6xl px-6 py-12">
      <p class="text-sm font-medium uppercase tracking-wide text-accent-600">
        Integrations
      </p>
      <h1 class="mt-2 text-3xl font-bold text-ink-900 sm:text-4xl">Harnesses</h1>
      <p class="mt-3 max-w-2xl text-ink-500">
        A harness is the runtime where you actually chat with the agent. Pick the one
        you already use — the same agent template installs in all of them.
      </p>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-6xl px-6 py-12">
      <div class="grid gap-6 sm:grid-cols-2">
        {HARNESSES.map((h) => (
          <a
            href={link(`/harnesses/${h.slug}`)}
            class="group flex flex-col rounded-xl border border-ink-200 bg-white p-6 transition hover:-translate-y-0.5 hover:border-accent-300 hover:shadow-md"
          >
            <HarnessLogo harness={h} size="h-12 w-12" />
            <h2 class="mt-4 text-xl font-semibold text-ink-900 group-hover:text-accent-700">
              {h.name}
            </h2>
            <p class="mt-1 text-sm leading-relaxed text-ink-500">{h.tagline}</p>
            <div class="mt-4">
              <CodeBlock
                code={`npx @vectorize-io/self-driving-agents install marketing/seo ${h.flag}`}
              />
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
