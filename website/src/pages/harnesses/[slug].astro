---
import Layout from '../../layouts/Layout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import { HARNESSES, type Harness } from '../../lib/harnesses';

export function getStaticPaths() {
  return HARNESSES.map((h) => ({
    params: { slug: h.slug },
    props: { harness: h },
  }));
}

interface Props {
  harness: Harness;
}
const { harness } = Astro.props;

const base = import.meta.env.BASE_URL;
const link = (p: string) => `${base.replace(/\/$/, '')}/${p.replace(/^\//, '')}`;
---

<Layout title={harness.name} description={harness.tagline}>
  <!-- Header -->
  <section class="border-b border-ink-200 bg-white">
    <div class="mx-auto max-w-4xl px-6 py-12">
      <nav class="mb-4 text-xs text-ink-400">
        <a href={link('/harnesses')} class="hover:text-ink-600">harnesses</a>
        <span class="mx-1">/</span>
        <span>{harness.slug}</span>
      </nav>

      <span
        class="inline-flex h-12 w-12 items-center justify-center rounded-xl text-white"
        style={`background-color: ${harness.color};`}
        aria-hidden="true"
      >
        ◉
      </span>
      <h1 class="mt-4 text-3xl font-bold text-ink-900 sm:text-4xl">
        {harness.name}
      </h1>
      <p class="mt-2 text-lg text-ink-500">{harness.tagline}</p>
      <code class="mt-4 inline-block rounded bg-ink-100 px-2 py-1 font-mono text-sm text-ink-700">
        {harness.flag}
      </code>
    </div>
  </section>

  <!-- Intro + audience -->
  <section class="border-b border-ink-200 bg-ink-50">
    <div class="mx-auto max-w-4xl px-6 py-10">
      <p class="text-base leading-relaxed text-ink-700">{harness.intro}</p>
      <div class="mt-5 rounded-xl border border-ink-200 bg-white p-4 text-sm text-ink-600">
        <span class="font-semibold text-ink-900">Who it's for:</span>{' '}
        {harness.audience}
      </div>
    </div>
  </section>

  <!-- Steps -->
  <section class="border-b border-ink-200 bg-white">
    <div class="mx-auto max-w-4xl px-6 py-10">
      <h2 class="text-xl font-semibold text-ink-900">How to run it</h2>
      <ol class="mt-6 space-y-6">
        {harness.steps.map((s, i) => (
          <li class="flex gap-4">
            <span
              class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-accent-500 text-sm font-semibold text-white"
            >
              {i + 1}
            </span>
            <div class="flex-1">
              <h3 class="font-semibold text-ink-900">{s.title}</h3>
              <p class="mt-1 text-sm leading-relaxed text-ink-600">{s.body}</p>
              {s.code && (
                <div class="mt-3">
                  <CodeBlock code={s.code} />
                </div>
              )}
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-b border-ink-200 bg-ink-50">
    <div class="mx-auto max-w-4xl px-6 py-10">
      <h2 class="text-xl font-semibold text-ink-900">Under the hood</h2>
      <ul class="mt-5 space-y-3 text-sm leading-relaxed text-ink-700">
        {harness.howItWorks.map((line) => (
          <li class="flex gap-3">
            <span class="mt-1 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-accent-500" />
            <span>{line}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Links -->
  {harness.links.length > 0 && (
    <section class="bg-white">
      <div class="mx-auto max-w-4xl px-6 py-10">
        <h2 class="text-xl font-semibold text-ink-900">Resources</h2>
        <div class="mt-4 flex flex-wrap gap-3">
          {harness.links.map((l) => (
            <a
              href={l.href}
              target="_blank"
              rel="noopener"
              class="rounded-lg border border-ink-200 bg-ink-50 px-4 py-2 text-sm font-medium text-ink-700 transition hover:border-accent-300 hover:bg-white"
            >
              {l.label} →
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
