---
const base = import.meta.env.BASE_URL;
const link = (p: string) => `${base.replace(/\/$/, '')}/${p.replace(/^\//, '')}`;

const nav = [
  { href: link('/'), label: 'Home' },
  { href: link('/agents'), label: 'Agents' },
  { href: link('/harnesses'), label: 'Harnesses' },
  { href: link('/quickstart'), label: 'Quick start' },
];
---

<header class="sticky top-0 z-30 border-b border-ink-200 bg-ink-50/80 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-3">
    <a href={link('/')} class="flex items-center gap-2 font-semibold text-ink-900">
      <span
        class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-accent-500 text-ink-50 shadow-sm"
        aria-hidden="true"
      >
        ◈
      </span>
      <span class="text-base">Self-Driving Agents</span>
    </a>

    <nav class="hidden items-center gap-1 md:flex">
      {nav.map((item) => (
        <a
          href={item.href}
          class="rounded-md px-3 py-1.5 text-sm font-medium text-ink-500 transition hover:bg-ink-100 hover:text-ink-900"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <a
        href="https://github.com/vectorize-io/self-driving-agents"
        target="_blank"
        rel="noopener"
        class="rounded-md border border-ink-200 bg-white px-3 py-1.5 text-sm font-medium text-ink-700 transition hover:border-ink-300 hover:bg-ink-50"
      >
        GitHub →
      </a>
    </div>
  </div>
</header>
